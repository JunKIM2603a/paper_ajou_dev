# IDE and local environments
.venv/

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/

# Raw and generated data
data/raw/**
data/processed/**
data/splits/**
!data/processed/
!data/splits/
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/splits/.gitkeep

# Experiment outputs and logs
experiments/outputs/**
experiments/logs/**
!experiments/outputs/
!experiments/logs/
!experiments/outputs/.gitkeep
!experiments/logs/.gitkeep

# Model artifacts and local tracking stores
*.pt
*.pth
*.ckpt
mlartifacts/
mlflow.db
experiments/logs/mlflow.db

